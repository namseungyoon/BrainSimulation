+#include <string>
+
+extern __constant__ float NESTGPUTimeResolution;
+
+namespace user_m5_ns
+{
+// The first five scalar states, both per-port states, and all legacy scalar and
+// port parameters deliberately retain the user_m2 order.  Everything appended
+// here is private state and cannot alter connection marshalling.
+enum ScalVarIndexes { i_V_m=0, i_V_d, i_V_dist, i_I_adap, i_I_dep,
+  i_V_b_prox, i_V_b_dist, i_h_prox, i_h_dist, i_n_prox, i_n_dist, N_SCAL_VAR };
+enum PortVarIndexes { i_g=0, i_g1, N_PORT_VAR };
+enum ScalParamIndexes { i_V_th=0, i_E_L, i_C_m, i_tau_m, i_k_adap, i_k1,
+  i_k2, i_A1, i_A2, i_I_e, i_V_peak, i_V_reset, i_t_ref, i_dend_C_frac,
+  i_dend_leak_scale, i_g_c, i_dist_C_frac, i_dist_leak_scale, i_g_c_dist,
+  i_refractory_step, i_den_delay, i_C_b_prox, i_C_b_dist,
+  i_g_leak_b_prox, i_g_leak_b_dist, i_g_b_prox, i_g_b_dist,
+  i_gbar_Na_prox, i_gbar_Na_dist, i_E_Na, i_Vm_half, i_km, i_Vh_half,
+  i_kh, i_tau_h, i_gbar_Kd_prox, i_gbar_Kd_dist, i_E_K, i_Vn_half,
+  i_kn, i_tau_n, N_SCAL_PARAM };
+enum PortParamIndexes { i_E_rev=0, i_tau_rise, i_tau_decay, i_g0, i_compartment, N_PORT_PARAM };
+enum GroupParamIndexes { i_h_min_rel=0, i_h0_rel, N_GROUP_PARAM };
+
+const std::string user_m5_scal_var_name[N_SCAL_VAR] = { "V_m", "V_d", "V_dist",
+  "I_adap", "I_dep", "V_b_prox", "V_b_dist", "h_Na_prox", "h_Na_dist",
+  "n_Kd_prox", "n_Kd_dist" };
+const std::string user_m5_port_var_name[N_PORT_VAR] = { "g", "g1" };
+const std::string user_m5_scal_param_name[N_SCAL_PARAM] = { "V_th", "E_L", "C_m",
+  "tau_m", "k_adap", "k1", "k2", "A1", "A2", "I_e", "V_peak", "V_reset",
+  "t_ref", "dend_C_frac", "dend_leak_scale", "g_c", "dist_C_frac",
+  "dist_leak_scale", "g_c_dist", "refractory_step", "den_delay", "C_b_prox",
+  "C_b_dist", "g_leak_b_prox", "g_leak_b_dist", "g_b_prox", "g_b_dist",
+  "gbar_Na_prox", "gbar_Na_dist", "E_Na", "Vm_half", "km", "Vh_half", "kh",
+  "tau_h", "gbar_Kd_prox", "gbar_Kd_dist", "E_K", "Vn_half", "kn", "tau_n" };
+const std::string user_m5_port_param_name[N_PORT_PARAM] =
+  { "E_rev", "tau_rise", "tau_decay", "g0", "compartment" };
+const std::string user_m5_group_param_name[N_GROUP_PARAM] = { "h_min_rel", "h0_rel" };
+
+#define V_m y[i_V_m]
+#define V_d y[i_V_d]
+#define V_dist y[i_V_dist]
+#define I_adap y[i_I_adap]
+#define I_dep y[i_I_dep]
+#define V_b_prox y[i_V_b_prox]
+#define V_b_dist y[i_V_b_dist]
+#define h_prox y[i_h_prox]
+#define h_dist y[i_h_dist]
+#define n_prox y[i_n_prox]
+#define n_dist y[i_n_dist]
+#define g(i) y[N_SCAL_VAR+N_PORT_VAR*(i)+i_g]
+#define g1(i) y[N_SCAL_VAR+N_PORT_VAR*(i)+i_g1]
+#define dVdt dydx[i_V_m]
+#define dVddt dydx[i_V_d]
+#define dVdistdt dydx[i_V_dist]
+#define dI_adapdt dydx[i_I_adap]
+#define dI_depdt dydx[i_I_dep]
+#define dV_b_proxdt dydx[i_V_b_prox]
+#define dV_b_distdt dydx[i_V_b_dist]
+#define dh_proxdt dydx[i_h_prox]
+#define dh_distdt dydx[i_h_dist]
+#define dn_proxdt dydx[i_n_prox]
+#define dn_distdt dydx[i_n_dist]
+#define dgdt(i) dydx[N_SCAL_VAR+N_PORT_VAR*(i)+i_g]
+#define dg1dt(i) dydx[N_SCAL_VAR+N_PORT_VAR*(i)+i_g1]
+#define P(name) param[i_##name]
+#define V_th P(V_th)
+#define E_L P(E_L)
+#define C_m P(C_m)
+#define tau_m P(tau_m)
+#define k_adap P(k_adap)
+#define k1 P(k1)
+#define k2 P(k2)
+#define A1 P(A1)
+#define A2 P(A2)
+#define I_e P(I_e)
+#define V_peak P(V_peak)
+#define V_reset P(V_reset)
+#define t_ref P(t_ref)
+#define dend_C_frac P(dend_C_frac)
+#define dend_leak_scale P(dend_leak_scale)
+#define g_c P(g_c)
+#define dist_C_frac P(dist_C_frac)
+#define dist_leak_scale P(dist_leak_scale)
+#define g_c_dist P(g_c_dist)
+#define refractory_step P(refractory_step)
+#define den_delay P(den_delay)
+#define C_b_prox P(C_b_prox)
+#define C_b_dist P(C_b_dist)
+#define g_leak_b_prox P(g_leak_b_prox)
+#define g_leak_b_dist P(g_leak_b_dist)
+#define g_b_prox P(g_b_prox)
+#define g_b_dist P(g_b_dist)
+#define gbar_Na_prox P(gbar_Na_prox)
+#define gbar_Na_dist P(gbar_Na_dist)
+#define E_Na P(E_Na)
+#define Vm_half P(Vm_half)
+#define km P(km)
+#define Vh_half P(Vh_half)
+#define kh P(kh)
+#define tau_h P(tau_h)
+#define gbar_Kd_prox P(gbar_Kd_prox)
+#define gbar_Kd_dist P(gbar_Kd_dist)
+#define E_K P(E_K)
+#define Vn_half P(Vn_half)
+#define kn P(kn)
+#define tau_n P(tau_n)
+#define E_rev(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_E_rev]
+#define tau_rise(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_tau_rise]
+#define tau_decay(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_tau_decay]
+#define g0(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_g0]
+#define compartment(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_compartment]
+#define h_min_rel_ group_param_[i_h_min_rel]
+#define h0_rel_ group_param_[i_h0_rel]
+
+__device__ inline float LogisticUp(float v,float half,float slope)
+{ float z=fminf(80.0f,fmaxf(-80.0f,-(v-half)/slope)); return 1.0f/(1.0f+expf(z)); }
+__device__ inline float LogisticDown(float v,float half,float slope)
+{ float z=fminf(80.0f,fmaxf(-80.0f,(v-half)/slope)); return 1.0f/(1.0f+expf(z)); }
+
+template<int NVAR,int NPARAM>
+__device__ void Derivatives(double,float* y,float* dydx,float* param,user_m5_rk5)
+{
+  enum { n_port=(NVAR-N_SCAL_VAR)/N_PORT_VAR };
+  const float V=refractory_step>0.0f?V_reset:fminf(V_m,V_peak);
+  float Is=0.0f,I_syn_bp=0.0f,I_syn_bd=0.0f;
+  for(int i=0;i<n_port;++i) {
+    if(compartment(i)<0.5f) Is+=g(i)*(E_rev(i)-V);
+    else if(compartment(i)<1.5f) I_syn_bp+=g(i)*(E_rev(i)-V_b_prox);
+    else I_syn_bd+=g(i)*(E_rev(i)-V_b_dist);
+  }
+  const float df=fminf(.95f,fmaxf(1.e-6f,dend_C_frac));
+  const float xf=fminf(.95f,fmaxf(1.e-6f,dist_C_frac));
+  const float cd=C_m*df, cdist=fmaxf(1.e-6f,cd*xf);
+  const float cprox=fmaxf(1.e-6f,cd-cdist), cs=fmaxf(1.e-6f,C_m-cd);
+  const float mp=LogisticUp(V_b_prox,Vm_half,km), md=LogisticUp(V_b_dist,Vm_half,km);
+  const float INap=gbar_Na_prox*mp*mp*mp*h_prox*(E_Na-V_b_prox);
+  const float INad=gbar_Na_dist*md*md*md*h_dist*(E_Na-V_b_dist);
+  const float IKp=gbar_Kd_prox*n_prox*n_prox*n_prox*n_prox*(E_K-V_b_prox);
+  const float IKd=gbar_Kd_dist*n_dist*n_dist*n_dist*n_dist*(E_K-V_b_dist);
+  // Rectification is intentional: this is a branch->domain transfer, not a
+  // fourth/fifth passive morphology compartment.  Somatic I_e therefore cannot
+  // back-drive or load a private branch, whereas a locally depolarized branch
+  // transfers its regenerative current into the historical domain voltage.
+  const float Ibp=g_b_prox*fmaxf(0.0f,V_b_prox-V_d);
+  const float Ibd=g_b_dist*fmaxf(0.0f,V_b_dist-V_dist);
+  dVdt=refractory_step>0.0f?0.0f:(-(cs/tau_m)*(V-E_L)+g_c*(V_d-V)-I_adap+I_dep+Is+I_e)/cs;
+  dVddt=(-(cprox/tau_m)*dend_leak_scale*(V_d-E_L)+g_c*(V-V_d)+g_c_dist*(V_dist-V_d)+Ibp)/cprox;
+  dVdistdt=(-(cdist/tau_m)*dist_leak_scale*(V_dist-E_L)+g_c_dist*(V_d-V_dist)+Ibd)/cdist;
+  dV_b_proxdt=(-g_leak_b_prox*(V_b_prox-E_L)-Ibp+I_syn_bp+INap+IKp)/fmaxf(1.e-6f,C_b_prox);
+  dV_b_distdt=(-g_leak_b_dist*(V_b_dist-E_L)-Ibd+I_syn_bd+INad+IKd)/fmaxf(1.e-6f,C_b_dist);
+  dI_adapdt=k_adap*(V-E_L)-k2*I_adap; dI_depdt=-k1*I_dep;
+  dh_proxdt=(LogisticDown(V_b_prox,Vh_half,kh)-h_prox)/tau_h;
+  dh_distdt=(LogisticDown(V_b_dist,Vh_half,kh)-h_dist)/tau_h;
+  dn_proxdt=(LogisticUp(V_b_prox,Vn_half,kn)-n_prox)/tau_n;
+  dn_distdt=(LogisticUp(V_b_dist,Vn_half,kn)-n_dist)/tau_n;
+  for(int i=0;i<n_port;++i) { dg1dt(i)=-g1(i)/tau_rise(i); dgdt(i)=g1(i)-g(i)/tau_decay(i); }
+}
+
+template<int NVAR,int NPARAM>
+__device__ void ExternalUpdate(double,float* y,float* param,bool end,user_m5_rk5 data)
+{
+  h_prox=fminf(1.f,fmaxf(0.f,h_prox)); h_dist=fminf(1.f,fmaxf(0.f,h_dist));
+  n_prox=fminf(1.f,fmaxf(0.f,n_prox)); n_dist=fminf(1.f,fmaxf(0.f,n_dist));
+  if(V_m < -1.e3f || V_d < -1.e3f || V_dist < -1.e3f ||
+     V_b_prox < -1.e3f || V_b_dist < -1.e3f) {
+    V_m=V_reset; V_d=E_L; V_dist=E_L; V_b_prox=E_L; V_b_dist=E_L;
+    I_adap=0; I_dep=0; return;
+  }
+  if(I_adap < -1.e6f || I_adap > 1.e6f || I_dep < -1.e6f || I_dep > 1.e6f) {
+    V_m=V_reset; I_adap=0; I_dep=0; return;
+  }
+  if(refractory_step>0.0f) { V_m=V_reset; if(end) refractory_step-=1.0f; }
+  else if(V_m>=V_th) {
+    const int idx=threadIdx.x+blockIdx.x*blockDim.x;
+    PushSpike(data.i_node_0_+idx,1.0); V_m=V_reset; I_adap+=A2; I_dep=A1;
+    refractory_step=(int)round(t_ref/NESTGPUTimeResolution);
+    if(refractory_step<0.0f) refractory_step=0.0f;
+  }
+}
+}
+
+template<> int user_m5::UpdateNR<0>(long long,double);
+template<int N_PORT> int user_m5::UpdateNR(long long it,double t1)
+{
+  if(N_PORT==n_port_) {
+    const int NV=user_m5_ns::N_SCAL_VAR+user_m5_ns::N_PORT_VAR*N_PORT;
+    const int NP=user_m5_ns::N_SCAL_PARAM+user_m5_ns::N_PORT_PARAM*N_PORT;
+    rk5_.Update<NV,NP>(t1,h_min_,rk5_data_struct_);
+  } else UpdateNR<N_PORT-1>(it,t1);
+  return 0;
+}
+template<int NV,int NP> __device__ void Derivatives(double x,float*y,float*d,float*p,user_m5_rk5 s)
+{ user_m5_ns::Derivatives<NV,NP>(x,y,d,p,s); }
+template<int NV,int NP> __device__ void ExternalUpdate(double x,float*y,float*p,bool e,user_m5_rk5 s)
+{ user_m5_ns::ExternalUpdate<NV,NP>(x,y,p,e,s); }
+#endif
