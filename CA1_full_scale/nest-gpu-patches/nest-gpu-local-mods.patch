+
+class user_m5 : public BaseNeuron
+{
+public:
+  RungeKutta5< user_m5_rk5 > rk5_;
+  float h_min_;
+  float h_;
+  user_m5_rk5 rk5_data_struct_;
+  int Init( int, int, int, int );
+  int Calibrate( double, float );
+  int Update( long long, double );
+  int GetX( int i, int n, double* x ) { return rk5_.GetX( i, n, x ); }
+  int GetY( int v, int i, int n, float* y ) { return rk5_.GetY( v, i, n, y ); }
+  template < int N_PORT > int UpdateNR( long long, double );
+};
+#endif
