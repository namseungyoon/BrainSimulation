diff --git a/src/user_m6_kernel.h b/src/user_m6_kernel.h
new file mode 100644
index 0000000..59d908e
--- /dev/null
+++ b/src/user_m6_kernel.h
@@ -0,0 +1,202 @@
+#ifndef USERM6KERNEL_H
+#define USERM6KERNEL_H
+
+#include "node_group.h"
+#include "spike_buffer.h"
+#include "user_m6.h"
+#include <cmath>
+#include <string>
+
+extern __constant__ float NESTGPUTimeResolution;
+
+namespace user_m6_ns
+{
+enum { MAX_BRANCH=4, MAX_PORT=20, LEGACY_SCAL_VAR=5,
+  BRANCH_STATE0=LEGACY_SCAL_VAR,
+  BRANCH_SYN0=BRANCH_STATE0+2*MAX_BRANCH*3,
+  N_SCAL_VAR=BRANCH_SYN0+MAX_PORT*MAX_BRANCH*2 };
+enum ScalVarIndexes { i_V_m=0, i_V_d, i_V_dist, i_I_adap, i_I_dep };
+enum PortVarIndexes { i_g=0, i_g1, N_PORT_VAR };
+enum ScalParamIndexes { i_V_th=0, i_E_L, i_C_m, i_tau_m, i_k_adap, i_k1,
+  i_k2, i_A1, i_A2, i_I_e, i_V_peak, i_V_reset, i_t_ref, i_dend_C_frac,
+  i_dend_leak_scale, i_g_c, i_dist_C_frac, i_dist_leak_scale, i_g_c_dist,
+  i_refractory_step, i_den_delay, i_C_b_prox, i_C_b_dist,
+  i_g_leak_b_prox, i_g_leak_b_dist, i_g_b_prox, i_g_b_dist,
+  i_gbar_Na_prox, i_gbar_Na_dist, i_E_Na, i_Vm_half, i_km, i_Vh_half,
+  i_kh, i_tau_h, i_gbar_Kd_prox, i_gbar_Kd_dist, i_E_K, i_Vn_half,
+  i_kn, i_tau_n, i_N_b, N_SCAL_PARAM };
+enum PortParamIndexes { i_E_rev=0, i_tau_rise, i_tau_decay, i_g0, i_compartment, N_PORT_PARAM };
+enum GroupParamIndexes { i_h_min_rel=0, i_h0_rel, N_GROUP_PARAM };
+
+const std::string user_m6_port_var_name[N_PORT_VAR] = { "g", "g1" };
+const std::string user_m6_scal_param_name[N_SCAL_PARAM] = { "V_th", "E_L", "C_m",
+  "tau_m", "k_adap", "k1", "k2", "A1", "A2", "I_e", "V_peak", "V_reset",
+  "t_ref", "dend_C_frac", "dend_leak_scale", "g_c", "dist_C_frac",
+  "dist_leak_scale", "g_c_dist", "refractory_step", "den_delay", "C_b_prox",
+  "C_b_dist", "g_leak_b_prox", "g_leak_b_dist", "g_b_prox", "g_b_dist",
+  "gbar_Na_prox", "gbar_Na_dist", "E_Na", "Vm_half", "km", "Vh_half", "kh",
+  "tau_h", "gbar_Kd_prox", "gbar_Kd_dist", "E_K", "Vn_half", "kn", "tau_n", "N_b" };
+const std::string user_m6_port_param_name[N_PORT_PARAM] =
+  { "E_rev", "tau_rise", "tau_decay", "g0", "compartment" };
+const std::string user_m6_group_param_name[N_GROUP_PARAM] = { "h_min_rel", "h0_rel" };
+
+__host__ __device__ inline int BState(int domain,int branch,int gate=0)
+{ return BRANCH_STATE0+(domain*MAX_BRANCH+branch)*3+gate; }
+__host__ __device__ inline int BSyn(int port,int branch,int phase=0)
+{ return BRANCH_SYN0+(port*MAX_BRANCH+branch)*2+phase; }
+
+#define V_m y[i_V_m]
+#define V_d y[i_V_d]
+#define V_dist y[i_V_dist]
+#define I_adap y[i_I_adap]
+#define I_dep y[i_I_dep]
+#define g(i) y[N_SCAL_VAR+N_PORT_VAR*(i)+i_g]
+#define g1(i) y[N_SCAL_VAR+N_PORT_VAR*(i)+i_g1]
+#define dVdt dydx[i_V_m]
+#define dVddt dydx[i_V_d]
+#define dVdistdt dydx[i_V_dist]
+#define dI_adapdt dydx[i_I_adap]
+#define dI_depdt dydx[i_I_dep]
+#define dgdt(i) dydx[N_SCAL_VAR+N_PORT_VAR*(i)+i_g]
+#define dg1dt(i) dydx[N_SCAL_VAR+N_PORT_VAR*(i)+i_g1]
+#define P(name) param[i_##name]
+#define V_th P(V_th)
+#define E_L P(E_L)
+#define C_m P(C_m)
+#define tau_m P(tau_m)
+#define k_adap P(k_adap)
+#define k1 P(k1)
+#define k2 P(k2)
+#define A1 P(A1)
+#define A2 P(A2)
+#define I_e P(I_e)
+#define V_peak P(V_peak)
+#define V_reset P(V_reset)
+#define t_ref P(t_ref)
+#define dend_C_frac P(dend_C_frac)
+#define dend_leak_scale P(dend_leak_scale)
+#define g_c P(g_c)
+#define dist_C_frac P(dist_C_frac)
+#define dist_leak_scale P(dist_leak_scale)
+#define g_c_dist P(g_c_dist)
+#define refractory_step P(refractory_step)
+#define den_delay P(den_delay)
+#define E_Na P(E_Na)
+#define Vm_half P(Vm_half)
+#define km P(km)
+#define Vh_half P(Vh_half)
+#define kh P(kh)
+#define tau_h P(tau_h)
+#define E_K P(E_K)
+#define Vn_half P(Vn_half)
+#define kn P(kn)
+#define tau_n P(tau_n)
+#define N_b P(N_b)
+#define E_rev(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_E_rev]
+#define tau_rise(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_tau_rise]
+#define tau_decay(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_tau_decay]
+#define g0(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_g0]
+#define compartment(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_compartment]
+#define h_min_rel_ group_param_[i_h_min_rel]
+#define h0_rel_ group_param_[i_h0_rel]
+
+__device__ inline float LogisticUp(float v,float half,float slope)
+{ float z=fminf(80.0f,fmaxf(-80.0f,-(v-half)/slope)); return 1.0f/(1.0f+expf(z)); }
+__device__ inline float LogisticDown(float v,float half,float slope)
+{ float z=fminf(80.0f,fmaxf(-80.0f,(v-half)/slope)); return 1.0f/(1.0f+expf(z)); }
+
+template<int NVAR,int NPARAM>
+__device__ void Derivatives(double,float* y,float* dydx,float* param,user_m6_rk5)
+{
+  enum { n_port=(NVAR-N_SCAL_VAR)/N_PORT_VAR };
+  const int nb=max(1,min(MAX_BRANCH,(int)roundf(N_b)));
+  const float V=refractory_step>0.0f?V_reset:fminf(V_m,V_peak);
+  float Is=0.0f, domain_current[2]={0.0f,0.0f};
+  float syn[2][MAX_BRANCH]={{0.0f}};
+  float branch_drive[2][MAX_BRANCH]={{0.0f}};
+  for(int i=0;i<MAX_PORT;++i) for(int b=0;b<MAX_BRANCH;++b) {
+    dydx[BSyn(i,b)]=0.0f; dydx[BSyn(i,b,1)]=0.0f;
+  }
+  for(int i=0;i<n_port;++i) {
+    if(compartment(i)<0.5f) Is+=g(i)*(E_rev(i)-V);
+    for(int b=0;b<MAX_BRANCH;++b) {
+      const float bg=y[BSyn(i,b)], bg1=y[BSyn(i,b,1)];
+      dydx[BSyn(i,b,1)]=-bg1/tau_rise(i);
+      dydx[BSyn(i,b)]=bg1-bg/tau_decay(i);
+      if(b<nb && compartment(i)>=0.5f) {
+        const int domain=compartment(i)<1.5f?0:1;
+        syn[domain][b]+=bg*(E_rev(i)-y[BState(domain,b)]);
+        branch_drive[domain][b]+=fabsf(bg);
+      }
+    }
+  }
+  const float df=fminf(.95f,fmaxf(1.e-6f,dend_C_frac));
+  const float xf=fminf(.95f,fmaxf(1.e-6f,dist_C_frac));
+  const float cd=C_m*df, cdist=fmaxf(1.e-6f,cd*xf);
+  const float cprox=fmaxf(1.e-6f,cd-cdist), cs=fmaxf(1.e-6f,C_m-cd);
+  for(int domain=0;domain<2;++domain) for(int b=0;b<MAX_BRANCH;++b) {
+    if(b>=nb) { dydx[BState(domain,b)]=0; dydx[BState(domain,b,1)]=0;
+      dydx[BState(domain,b,2)]=0; continue; }
+    if(branch_drive[domain][b]<=0.0f) {
+      dydx[BState(domain,b)]=0; dydx[BState(domain,b,1)]=0;
+      dydx[BState(domain,b,2)]=0; continue;
+    }
+    const float vb=y[BState(domain,b)], h=y[BState(domain,b,1)], n=y[BState(domain,b,2)];
+    const float vd=domain==0?V_d:V_dist;
+    const float cb=domain==0?P(C_b_prox):P(C_b_dist);
+    const float gl=domain==0?P(g_leak_b_prox):P(g_leak_b_dist);
+    const float gb=domain==0?P(g_b_prox):P(g_b_dist);
+    const float gna=domain==0?P(gbar_Na_prox):P(gbar_Na_dist);
+    const float gkd=domain==0?P(gbar_Kd_prox):P(gbar_Kd_dist);
+    const float m=LogisticUp(vb,Vm_half,km);
+    const float ina=gna*m*m*m*h*(E_Na-vb);
+    const float ik=gkd*n*n*n*n*(E_K-vb);
+    const float coupling=gb*fmaxf(0.0f,vb-vd);
+    domain_current[domain]+=coupling;
+    dydx[BState(domain,b)]=(-gl*(vb-E_L)-coupling+syn[domain][b]+ina+ik)/fmaxf(1.e-6f,cb);
+    dydx[BState(domain,b,1)]=(LogisticDown(vb,Vh_half,kh)-h)/tau_h;
+    dydx[BState(domain,b,2)]=(LogisticUp(vb,Vn_half,kn)-n)/tau_n;
+  }
+  dVdt=refractory_step>0.0f?0.0f:(-(cs/tau_m)*(V-E_L)+g_c*(V_d-V)-I_adap+I_dep+Is+I_e)/cs;
+  dVddt=(-(cprox/tau_m)*dend_leak_scale*(V_d-E_L)+g_c*(V-V_d)+g_c_dist*(V_dist-V_d)+domain_current[0])/cprox;
+  dVdistdt=(-(cdist/tau_m)*dist_leak_scale*(V_dist-E_L)+g_c_dist*(V_d-V_dist)+domain_current[1])/cdist;
+  dI_adapdt=k_adap*(V-E_L)-k2*I_adap; dI_depdt=-k1*I_dep;
+  for(int i=0;i<n_port;++i) { dg1dt(i)=-g1(i)/tau_rise(i); dgdt(i)=g1(i)-g(i)/tau_decay(i); }
+}
+
+template<int NVAR,int NPARAM>
+__device__ void ExternalUpdate(double,float* y,float* param,bool end,user_m6_rk5 data)
+{
+  const int nb=max(1,min(MAX_BRANCH,(int)roundf(N_b)));
+  for(int domain=0;domain<2;++domain) for(int b=0;b<nb;++b) {
+    y[BState(domain,b,1)]=fminf(1.f,fmaxf(0.f,y[BState(domain,b,1)]));
+    y[BState(domain,b,2)]=fminf(1.f,fmaxf(0.f,y[BState(domain,b,2)]));
+  }
+  if(V_m < -1.e3f || V_d < -1.e3f || V_dist < -1.e3f) {
+    V_m=V_reset; V_d=E_L; V_dist=E_L; I_adap=0; I_dep=0; return;
+  }
+  if(refractory_step>0.0f) { V_m=V_reset; if(end) refractory_step-=1.0f; }
+  else if(V_m>=V_th) {
+    const int idx=threadIdx.x+blockIdx.x*blockDim.x;
+    PushSpike(data.i_node_0_+idx,1.0); V_m=V_reset; I_adap+=A2; I_dep=A1;
+    refractory_step=(int)round(t_ref/NESTGPUTimeResolution);
+    if(refractory_step<0.0f) refractory_step=0.0f;
+  }
+}
+}
+
+template<> int user_m6::UpdateNR<0>(long long,double);
+template<int N_PORT> int user_m6::UpdateNR(long long it,double t1)
+{
+  if(N_PORT==n_port_) {
+    const int NV=user_m6_ns::N_SCAL_VAR+user_m6_ns::N_PORT_VAR*N_PORT;
+    const int NP=user_m6_ns::N_SCAL_PARAM+user_m6_ns::N_PORT_PARAM*N_PORT;
+    rk5_.Update<NV,NP>(t1,h_min_,rk5_data_struct_);
+  } else UpdateNR<N_PORT-1>(it,t1);
+  return 0;
+}
+template<int NV,int NP> __device__ void Derivatives(double x,float*y,float*d,float*p,user_m6_rk5 s)
+{ user_m6_ns::Derivatives<NV,NP>(x,y,d,p,s); }
+template<int NV,int NP> __device__ void ExternalUpdate(double x,float*y,float*p,bool e,user_m6_rk5 s)
+{ user_m6_ns::ExternalUpdate<NV,NP>(x,y,p,e,s); }
+#endif
