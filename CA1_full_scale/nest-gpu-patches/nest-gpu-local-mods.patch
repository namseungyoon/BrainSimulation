diff --git a/src/user_m4.cu b/src/user_m4.cu
new file mode 100644
index 0000000..a259dad
--- /dev/null
+++ b/src/user_m4.cu
@@ -0,0 +1,66 @@
+#include "rk5.h"
+#include "user_m4.h"
+#include "user_m4_kernel.h"
+#include <cmath>
+
+namespace user_m4_ns
+{
+__device__ void NodeInit(int n_var,int,double,float*y,float*param,user_m4_rk5)
+{
+  const int n_port=(n_var-N_SCAL_VAR)/N_PORT_VAR;
+  V_th=-50.f; E_L=-65.f; C_m=200.f; tau_m=20.f; k_adap=0.f; k1=.1f; k2=.01f;
+  A1=0.f; A2=0.f; I_e=0.f; V_peak=0.f; V_reset=-65.f; t_ref=2.f;
+  dend_C_frac=.4f; dend_leak_scale=1.f; g_c=10.f; dist_C_frac=.5f;
+  dist_leak_scale=1.f; g_c_dist=2.5f; den_delay=0.f;
+  gbar_Na_prox=0.f; gbar_Na_dist=0.f; E_Na=55.f; Vm_half=-35.f; km=7.f;
+  Vh_half=-50.f; kh=6.f; tau_h=2.f; gbar_Kd_prox=0.f; gbar_Kd_dist=0.f;
+  E_K=-90.f; Vn_half=-25.f; kn=10.f; tau_n=2.f;
+  V_m=E_L; V_d=E_L; V_dist=E_L; I_adap=0.f; I_dep=0.f;
+  h_prox=LogisticDown(E_L,Vh_half,kh); h_dist=h_prox;
+  n_prox=LogisticUp(E_L,Vn_half,kn); n_dist=n_prox; refractory_step=0.f;
+  for(int i=0;i<n_port;++i) { g(i)=0.f; g1(i)=0.f; E_rev(i)=0.f;
+    tau_decay(i)=20.f; tau_rise(i)=2.f; compartment(i)=1.f; }
+}
+
+__device__ void NodeCalibrate(int n_var,int,double,float*y,float*param,user_m4_rk5)
+{
+  const int n_port=(n_var-N_SCAL_VAR)/N_PORT_VAR; refractory_step=0.f;
+  h_prox=fminf(1.f,fmaxf(0.f,h_prox)); h_dist=fminf(1.f,fmaxf(0.f,h_dist));
+  n_prox=fminf(1.f,fmaxf(0.f,n_prox)); n_dist=fminf(1.f,fmaxf(0.f,n_dist));
+  for(int i=0;i<n_port;++i) {
+    const float d1=tau_decay(i)-tau_rise(i); float d2=0.f;
+    if(d1!=0.f) { const float tp=tau_decay(i)*tau_rise(i)*log(tau_decay(i)/tau_rise(i))/d1;
+      d2=exp(-tp/tau_decay(i))-exp(-tp/tau_rise(i)); }
+    g0(i)=d2==0.f?M_E/tau_decay(i):(1.f/tau_rise(i)-1.f/tau_decay(i))/d2;
+  }
+}
+}
+__device__ void NodeInit(int nv,int np,double x,float*y,float*p,user_m4_rk5 d)
+{ user_m4_ns::NodeInit(nv,np,x,y,p,d); }
+__device__ void NodeCalibrate(int nv,int np,double x,float*y,float*p,user_m4_rk5 d)
+{ user_m4_ns::NodeCalibrate(nv,np,x,y,p,d); }
+
+using namespace user_m4_ns;
+int user_m4::Init(int i0,int nn,int np,int ig)
+{
+  BaseNeuron::Init(i0,nn,np,ig); node_type_=i_user_m4_model;
+  n_scal_var_=N_SCAL_VAR; n_port_var_=N_PORT_VAR; n_scal_param_=N_SCAL_PARAM;
+  n_port_param_=N_PORT_PARAM; n_group_param_=N_GROUP_PARAM;
+  n_var_=n_scal_var_+n_port_var_*np; n_param_=n_scal_param_+n_port_param_*np;
+  group_param_=new float[N_GROUP_PARAM]; scal_var_name_=user_m4_scal_var_name;
+  port_var_name_=user_m4_port_var_name; scal_param_name_=user_m4_scal_param_name;
+  port_param_name_=user_m4_port_param_name; group_param_name_=user_m4_group_param_name;
+  rk5_data_struct_.i_node_0_=i_node_0_; SetGroupParam("h_min_rel",1.e-3);
+  SetGroupParam("h0_rel",1.e-2); h_=h0_rel_*.1f;
+  rk5_.Init(nn,n_var_,n_param_,0.,h_,rk5_data_struct_);
+  var_arr_=rk5_.GetYArr(); param_arr_=rk5_.GetParamArr();
+  port_weight_arr_=GetParamArr()+n_scal_param_+GetPortParamIdx("g0");
+  port_weight_arr_step_=n_param_; port_weight_port_step_=n_port_param_;
+  port_input_arr_=GetVarArr()+n_scal_var_+GetPortVarIdx("g1");
+  port_input_arr_step_=n_var_; port_input_port_step_=n_port_var_;
+  den_delay_arr_=GetParamArr()+GetScalParamIdx("den_delay"); return 0;
+}
+int user_m4::Calibrate(double t,float dt)
+{ h_min_=h_min_rel_*dt; h_=h0_rel_*dt; rk5_.Calibrate(t,h_,rk5_data_struct_); return 0; }
+template<> int user_m4::UpdateNR<0>(long long,double){return 0;}
+int user_m4::Update(long long it,double t){UpdateNR<USER_M4_MAX_PORT_NUM>(it,t);return 0;}
