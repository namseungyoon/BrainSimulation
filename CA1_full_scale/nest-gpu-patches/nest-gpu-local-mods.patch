+#ifndef USERM7_H
+#define USERM7_H
+#include "base_neuron.h"
+#include "neuron_models.h"
+#include "rk5.h"
+#define USER_M7_MAX_PORT_NUM 20
+struct user_m7_rk5 { int i_node_0_; };
+class user_m7 : public BaseNeuron
+{
+public:
+  RungeKutta5< user_m7_rk5 > rk5_;
+  std::string* scal_var_name_storage_;
+  std::string* scal_param_name_storage_;
+  float h_min_, h_;
+  user_m7_rk5 rk5_data_struct_;
+  int Init( int, int, int, int );
+  int Calibrate( double, float );
+  int Update( long long, double );
+  int GetX( int i, int n, double* x ) { return rk5_.GetX( i, n, x ); }
+  int GetY( int v, int i, int n, float* y ) { return rk5_.GetY( v, i, n, y ); }
+  template < int N_PORT > int UpdateNR( long long, double );
+};
+#endif
diff --git a/src/user_m7_kernel.h b/src/user_m7_kernel.h
new file mode 100644
index 0000000..43883c5
--- /dev/null
+++ b/src/user_m7_kernel.h
@@ -0,0 +1,178 @@
+#ifndef USERM7KERNEL_H
+#define USERM7KERNEL_H
+#include "node_group.h"
+#include "spike_buffer.h"
+#include "user_m7.h"
+#include <cmath>
+#include <string>
+extern __constant__ float NESTGPUTimeResolution;
+namespace user_m7_ns
+{
+enum { MAX_BRANCH=4, MAX_PORT=20, LEGACY_SCAL_VAR=5, BRANCH_STATE0=5,
+  BRANCH_SYN0=BRANCH_STATE0+2*MAX_BRANCH*3,
+  N_SCAL_VAR=BRANCH_SYN0+MAX_PORT*MAX_BRANCH*2 };
+enum ScalVarIndexes { i_V_m=0, i_V_d, i_V_dist, i_I_adap, i_I_dep };
+enum PortVarIndexes { i_g=0, i_g1, N_PORT_VAR };
+enum ScalParamIndexes { i_V_th=0, i_E_L, i_C_m, i_tau_m, i_k_adap, i_k1,
+  i_k2, i_A1, i_A2, i_I_e, i_V_peak, i_V_reset, i_t_ref, i_dend_C_frac,
+  i_dend_leak_scale, i_g_c, i_dist_C_frac, i_dist_leak_scale, i_g_c_dist,
+  i_refractory_step, i_den_delay, i_C_b_prox_0, i_C_b_dist_0=25,
+  i_g_leak_b_prox_0=29, i_g_leak_b_dist_0=33, i_g_ax_b_prox_0=37,
+  i_g_ax_b_dist_0=41, i_gbar_Na_prox_0=45, i_gbar_Na_dist_0=49,
+  i_gbar_Kd_prox_0=53, i_gbar_Kd_dist_0=57, i_E_Na=61, i_Vm_half,
+  i_km, i_Vh_half, i_kh, i_tau_h, i_E_K, i_Vn_half, i_kn, i_tau_n,
+  N_SCAL_PARAM };
+enum PortParamIndexes { i_E_rev=0, i_tau_rise, i_tau_decay, i_g0, i_compartment, N_PORT_PARAM };
+enum GroupParamIndexes { i_h_min_rel=0, i_h0_rel, N_GROUP_PARAM };
+const std::string user_m7_port_var_name[N_PORT_VAR] = { "g", "g1" };
+const std::string user_m7_port_param_name[N_PORT_PARAM] =
+  { "E_rev", "tau_rise", "tau_decay", "g0", "compartment" };
+const std::string user_m7_group_param_name[N_GROUP_PARAM] = { "h_min_rel", "h0_rel" };
+__host__ __device__ inline int BState(int domain,int branch,int gate=0)
+{ return BRANCH_STATE0+(domain*MAX_BRANCH+branch)*3+gate; }
+__host__ __device__ inline int BSyn(int port,int branch,int phase=0)
+{ return BRANCH_SYN0+(port*MAX_BRANCH+branch)*2+phase; }
+#define V_m y[i_V_m]
+#define V_d y[i_V_d]
+#define V_dist y[i_V_dist]
+#define I_adap y[i_I_adap]
+#define I_dep y[i_I_dep]
+#define g(i) y[N_SCAL_VAR+N_PORT_VAR*(i)+i_g]
+#define g1(i) y[N_SCAL_VAR+N_PORT_VAR*(i)+i_g1]
+#define dVdt dydx[i_V_m]
+#define dVddt dydx[i_V_d]
+#define dVdistdt dydx[i_V_dist]
+#define dI_adapdt dydx[i_I_adap]
+#define dI_depdt dydx[i_I_dep]
+#define dgdt(i) dydx[N_SCAL_VAR+N_PORT_VAR*(i)+i_g]
+#define dg1dt(i) dydx[N_SCAL_VAR+N_PORT_VAR*(i)+i_g1]
+#define P(name) param[i_##name]
+#define V_th P(V_th)
+#define E_L P(E_L)
+#define C_m P(C_m)
+#define tau_m P(tau_m)
+#define k_adap P(k_adap)
+#define k1 P(k1)
+#define k2 P(k2)
+#define A1 P(A1)
+#define A2 P(A2)
+#define I_e P(I_e)
+#define V_peak P(V_peak)
+#define V_reset P(V_reset)
+#define t_ref P(t_ref)
+#define dend_C_frac P(dend_C_frac)
+#define dend_leak_scale P(dend_leak_scale)
+#define g_c P(g_c)
+#define dist_C_frac P(dist_C_frac)
+#define dist_leak_scale P(dist_leak_scale)
+#define g_c_dist P(g_c_dist)
+#define refractory_step P(refractory_step)
+#define den_delay P(den_delay)
+#define E_Na P(E_Na)
+#define Vm_half P(Vm_half)
+#define km P(km)
+#define Vh_half P(Vh_half)
+#define kh P(kh)
+#define tau_h P(tau_h)
+#define E_K P(E_K)
+#define Vn_half P(Vn_half)
+#define kn P(kn)
+#define tau_n P(tau_n)
+#define E_rev(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_E_rev]
+#define tau_rise(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_tau_rise]
+#define tau_decay(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_tau_decay]
+#define g0(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_g0]
+#define compartment(i) param[N_SCAL_PARAM+N_PORT_PARAM*(i)+i_compartment]
+#define h_min_rel_ group_param_[i_h_min_rel]
+#define h0_rel_ group_param_[i_h0_rel]
+__device__ inline float LogisticUp(float v,float half,float slope)
+{ float z=fminf(80.f,fmaxf(-80.f,-(v-half)/slope)); return 1.f/(1.f+expf(z)); }
+__device__ inline float LogisticDown(float v,float half,float slope)
+{ float z=fminf(80.f,fmaxf(-80.f,(v-half)/slope)); return 1.f/(1.f+expf(z)); }
+
+template<int NVAR,int NPARAM>
+__device__ void Derivatives(double,float* y,float* dydx,float* param,user_m7_rk5)
+{
+  enum { n_port=(NVAR-N_SCAL_VAR)/N_PORT_VAR };
+  const float V=refractory_step>0.f?V_reset:fminf(V_m,V_peak);
+  float soma_syn=0.f, domain_reaction[2]={0.f,0.f}, syn[2][MAX_BRANCH]={{0.f}};
+  for(int i=0;i<MAX_PORT;++i) for(int b=0;b<MAX_BRANCH;++b) {
+    dydx[BSyn(i,b)]=0.f; dydx[BSyn(i,b,1)]=0.f;
+  }
+  for(int i=0;i<n_port;++i) {
+    if(compartment(i)<.5f) soma_syn+=g(i)*(E_rev(i)-V);
+    for(int b=0;b<MAX_BRANCH;++b) {
+      float bg=y[BSyn(i,b)], bg1=y[BSyn(i,b,1)];
+      dydx[BSyn(i,b,1)]=-bg1/tau_rise(i);
+      dydx[BSyn(i,b)]=bg1-bg/tau_decay(i);
+      if(compartment(i)>=.5f) {
+        int d=compartment(i)<1.5f?0:1;
+        syn[d][b]+=bg*(E_rev(i)-y[BState(d,b)]);
+      }
+    }
+  }
+  const float df=fminf(.95f,fmaxf(1.e-6f,dend_C_frac));
+  const float xf=fminf(.95f,fmaxf(1.e-6f,dist_C_frac));
+  const float cd=C_m*df, cdist=fmaxf(1.e-6f,cd*xf);
+  const float cprox=fmaxf(1.e-6f,cd-cdist), cs=fmaxf(1.e-6f,C_m-cd);
+  for(int d=0;d<2;++d) for(int b=0;b<MAX_BRANCH;++b) {
+    float vb=y[BState(d,b)], h=y[BState(d,b,1)], n=y[BState(d,b,2)];
+    float vd=d==0?V_d:V_dist;
+    int cb0=d==0?i_C_b_prox_0:i_C_b_dist_0;
+    int gl0=d==0?i_g_leak_b_prox_0:i_g_leak_b_dist_0;
+    int ga0=d==0?i_g_ax_b_prox_0:i_g_ax_b_dist_0;
+    int na0=d==0?i_gbar_Na_prox_0:i_gbar_Na_dist_0;
+    int kd0=d==0?i_gbar_Kd_prox_0:i_gbar_Kd_dist_0;
+    float m=LogisticUp(vb,Vm_half,km);
+    float ina=param[na0+b]*m*m*m*h*(E_Na-vb);
+    float ik=param[kd0+b]*n*n*n*n*(E_K-vb);
+    float axial=param[ga0+b]*(vd-vb);
+    domain_reaction[d]-=axial;
+    dydx[BState(d,b)]=(-param[gl0+b]*(vb-E_L)+axial+syn[d][b]+ina+ik)
+      /fmaxf(1.e-6f,param[cb0+b]);
+    dydx[BState(d,b,1)]=(LogisticDown(vb,Vh_half,kh)-h)/tau_h;
+    dydx[BState(d,b,2)]=(LogisticUp(vb,Vn_half,kn)-n)/tau_n;
+  }
+  dVdt=refractory_step>0.f?0.f:(-(cs/tau_m)*(V-E_L)+g_c*(V_d-V)-I_adap+I_dep+soma_syn+I_e)/cs;
+  dVddt=(-(cprox/tau_m)*dend_leak_scale*(V_d-E_L)+g_c*(V-V_d)
+    +g_c_dist*(V_dist-V_d)+domain_reaction[0])/cprox;
+  dVdistdt=(-(cdist/tau_m)*dist_leak_scale*(V_dist-E_L)+g_c_dist*(V_d-V_dist)
+    +domain_reaction[1])/cdist;
+  dI_adapdt=k_adap*(V-E_L)-k2*I_adap; dI_depdt=-k1*I_dep;
+  for(int i=0;i<n_port;++i) { dg1dt(i)=-g1(i)/tau_rise(i); dgdt(i)=g1(i)-g(i)/tau_decay(i); }
+}
+
+template<int NVAR,int NPARAM>
+__device__ void ExternalUpdate(double,float* y,float* param,bool end,user_m7_rk5 data)
+{
+  for(int d=0;d<2;++d) for(int b=0;b<MAX_BRANCH;++b) {
+    y[BState(d,b,1)]=fminf(1.f,fmaxf(0.f,y[BState(d,b,1)]));
+    y[BState(d,b,2)]=fminf(1.f,fmaxf(0.f,y[BState(d,b,2)]));
+  }
+  if(V_m < -1.e3f || V_d < -1.e3f || V_dist < -1.e3f) {
+    V_m=V_reset; V_d=E_L; V_dist=E_L; I_adap=0; I_dep=0; return;
+  }
+  if(refractory_step>0.f) { V_m=V_reset; if(end) refractory_step-=1.f; }
+  else if(V_m>=V_th) {
+    int idx=threadIdx.x+blockIdx.x*blockDim.x;
+    PushSpike(data.i_node_0_+idx,1.0); V_m=V_reset; I_adap+=A2; I_dep=A1;
+    refractory_step=(int)round(t_ref/NESTGPUTimeResolution);
+    if(refractory_step<0.f) refractory_step=0.f;
+  }
+}
+}
+template<> int user_m7::UpdateNR<0>(long long,double);
+template<int N_PORT> int user_m7::UpdateNR(long long it,double t1)
+{
+  if(N_PORT==n_port_) {
+    const int NV=user_m7_ns::N_SCAL_VAR+user_m7_ns::N_PORT_VAR*N_PORT;
+    const int NP=user_m7_ns::N_SCAL_PARAM+user_m7_ns::N_PORT_PARAM*N_PORT;
+    rk5_.Update<NV,NP>(t1,h_min_,rk5_data_struct_);
+  } else UpdateNR<N_PORT-1>(it,t1);
+  return 0;
+}
+template<int NV,int NP> __device__ void Derivatives(double x,float*y,float*d,float*p,user_m7_rk5 s)
+{ user_m7_ns::Derivatives<NV,NP>(x,y,d,p,s); }
+template<int NV,int NP> __device__ void ExternalUpdate(double x,float*y,float*p,bool e,user_m7_rk5 s)
+{ user_m7_ns::ExternalUpdate<NV,NP>(x,y,p,e,s); }
+#endif
