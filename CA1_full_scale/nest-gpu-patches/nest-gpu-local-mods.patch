+#include "rk5.h"
+#include "user_m3.h"
+#include "user_m3_kernel.h"
+#include <cmath>
+
+namespace user_m3_ns
+{
+__device__ void NodeInit( int n_var, int, double, float* y, float* param, user_m3_rk5 )
+{
+  int n_port = ( n_var - N_SCAL_VAR ) / N_PORT_VAR;
+  V_th = -50.0f; E_L = -65.0f; C_m = 200.0f; tau_m = 20.0f;
+  k_adap = 0.0f; k1 = 0.1f; k2 = 0.01f; A1 = 0.0f; A2 = 0.0f; I_e = 0.0f;
+  V_peak = 0.0f; V_reset = -65.0f; t_ref = 2.0f;
+  dend_C_frac = 0.4f; dend_leak_scale = 1.0f; g_c = 10.0f;
+  dist_C_frac = 0.5f; dist_leak_scale = 1.0f; g_c_dist = 2.5f; den_delay = 0.0f;
+  V_h_half = -42.0f; k_h = 7.0f; tau_h = 66.97f;
+  delta_h = 0.225f; h_crit = 0.35f;
+  V_m = E_L; V_d = E_L; V_dist = E_L; I_adap = 0.0f; I_dep = 0.0f;
+  sodium_h = SodiumHInf( E_L, V_h_half, k_h ); refractory_step = 0.0f;
+  for ( int i = 0; i < n_port; ++i )
+  {
+    g( i ) = 0.0f; g1( i ) = 0.0f; E_rev( i ) = 0.0f;
+    tau_decay( i ) = 20.0f; tau_rise( i ) = 2.0f; compartment( i ) = 1.0f;
+  }
+}
+
+__device__ void NodeCalibrate( int n_var, int, double, float* y, float* param, user_m3_rk5 )
+{
+  int n_port = ( n_var - N_SCAL_VAR ) / N_PORT_VAR;
+  refractory_step = 0.0f;
+  sodium_h = fminf( 1.0f, fmaxf( 0.0f, sodium_h ) );
+  for ( int i = 0; i < n_port; ++i )
+  {
+    float denom1 = tau_decay( i ) - tau_rise( i ), denom2 = 0.0f;
+    if ( denom1 != 0.0f )
+    {
+      float tp = tau_decay( i ) * tau_rise( i ) * log( tau_decay( i ) / tau_rise( i ) ) / denom1;
+      denom2 = exp( -tp / tau_decay( i ) ) - exp( -tp / tau_rise( i ) );
+    }
+    g0( i ) = denom2 == 0.0f ? M_E / tau_decay( i )
+      : ( 1.0f / tau_rise( i ) - 1.0f / tau_decay( i ) ) / denom2;
+  }
+}
+} // namespace user_m3_ns
+
+__device__ void NodeInit( int nv, int np, double x, float* y, float* p, user_m3_rk5 d )
+{ user_m3_ns::NodeInit( nv, np, x, y, p, d ); }
+__device__ void NodeCalibrate( int nv, int np, double x, float* y, float* p, user_m3_rk5 d )
+{ user_m3_ns::NodeCalibrate( nv, np, x, y, p, d ); }
+
+using namespace user_m3_ns;
+
+int user_m3::Init( int i_node_0, int n_node, int n_port, int i_group )
+{
+  BaseNeuron::Init( i_node_0, n_node, n_port, i_group );
+  node_type_ = i_user_m3_model;
+  n_scal_var_ = N_SCAL_VAR; n_port_var_ = N_PORT_VAR;
+  n_scal_param_ = N_SCAL_PARAM; n_port_param_ = N_PORT_PARAM; n_group_param_ = N_GROUP_PARAM;
+  n_var_ = n_scal_var_ + n_port_var_ * n_port;
+  n_param_ = n_scal_param_ + n_port_param_ * n_port;
+  group_param_ = new float[ N_GROUP_PARAM ];
+  scal_var_name_ = user_m3_scal_var_name; port_var_name_ = user_m3_port_var_name;
+  scal_param_name_ = user_m3_scal_param_name; port_param_name_ = user_m3_port_param_name;
+  group_param_name_ = user_m3_group_param_name;
+  rk5_data_struct_.i_node_0_ = i_node_0_;
+  SetGroupParam( "h_min_rel", 1.0e-3 ); SetGroupParam( "h0_rel", 1.0e-2 );
+  h_ = h0_rel_ * 0.1f;
+  rk5_.Init( n_node, n_var_, n_param_, 0.0, h_, rk5_data_struct_ );
+  var_arr_ = rk5_.GetYArr(); param_arr_ = rk5_.GetParamArr();
+  port_weight_arr_ = GetParamArr() + n_scal_param_ + GetPortParamIdx( "g0" );
+  port_weight_arr_step_ = n_param_; port_weight_port_step_ = n_port_param_;
+  port_input_arr_ = GetVarArr() + n_scal_var_ + GetPortVarIdx( "g1" );
+  port_input_arr_step_ = n_var_; port_input_port_step_ = n_port_var_;
+  den_delay_arr_ = GetParamArr() + GetScalParamIdx( "den_delay" );
+  return 0;
+}
+int user_m3::Calibrate( double time_min, float dt )
+{
+  h_min_ = h_min_rel_ * dt; h_ = h0_rel_ * dt;
+  rk5_.Calibrate( time_min, h_, rk5_data_struct_ ); return 0;
+}
+template <> int user_m3::UpdateNR< 0 >( long long, double ) { return 0; }
+int user_m3::Update( long long it, double t1 )
+{ UpdateNR< USER_M3_MAX_PORT_NUM >( it, t1 ); return 0; }
