diff --git a/src/user_m7.cu b/src/user_m7.cu
new file mode 100644
index 0000000..596bb9b
--- /dev/null
+++ b/src/user_m7.cu
@@ -0,0 +1,96 @@
+#include "rk5.h"
+#include "user_m7.h"
+#include "user_m7_kernel.h"
+#include <cmath>
+namespace user_m7_ns
+{
+__device__ void NodeInit(int n_var,int,double,float*y,float*param,user_m7_rk5)
+{
+  const int n_port=(n_var-N_SCAL_VAR)/N_PORT_VAR;
+  V_th=-50.f; E_L=-65.f; C_m=200.f; tau_m=20.f; k_adap=0.f; k1=.1f; k2=.01f;
+  A1=0.f; A2=0.f; I_e=0.f; V_peak=0.f; V_reset=-65.f; t_ref=2.f;
+  dend_C_frac=.4f; dend_leak_scale=1.f; g_c=10.f; dist_C_frac=.5f;
+  dist_leak_scale=1.f; g_c_dist=2.5f; den_delay=0.f;
+  const float cp[4]={30.788f,30.788f,15.394f,15.394f};
+  const float cd[4]={28.589f,28.589f,4.398f,4.398f};
+  const float glp[4]={3.959f,3.959f,1.979f,1.979f};
+  const float gld[4]={3.676f,3.676f,.566f,.566f};
+  const float gap[4]={100.f,100.f,30.f,30.f};
+  const float gad[4]={20.f,20.f,8.f,8.f};
+  const float nap[4]={3298.670f,3298.670f,1649.335f,1649.335f};
+  const float nad[4]={3063.056f,3063.056f,471.239f,471.239f};
+  const float kdp[4]={285.885f,285.885f,142.942f,142.942f};
+  const float kdd[4]={265.465f,265.465f,40.841f,40.841f};
+  for(int b=0;b<4;++b) { param[i_C_b_prox_0+b]=cp[b]; param[i_C_b_dist_0+b]=cd[b];
+    param[i_g_leak_b_prox_0+b]=glp[b]; param[i_g_leak_b_dist_0+b]=gld[b];
+    param[i_g_ax_b_prox_0+b]=gap[b]; param[i_g_ax_b_dist_0+b]=gad[b];
+    param[i_gbar_Na_prox_0+b]=nap[b]; param[i_gbar_Na_dist_0+b]=nad[b];
+    param[i_gbar_Kd_prox_0+b]=kdp[b]; param[i_gbar_Kd_dist_0+b]=kdd[b]; }
+  E_Na=55.f; Vm_half=-30.f; km=2.5f; Vh_half=-35.f; kh=4.f; tau_h=8.711f;
+  E_K=-90.f; Vn_half=-26.5556f; kn=7.9568f; tau_n=2.744f;
+  V_m=E_L; V_d=E_L; V_dist=E_L; I_adap=0.f; I_dep=0.f; refractory_step=0.f;
+  float h=LogisticDown(E_L,Vh_half,kh), n=LogisticUp(E_L,Vn_half,kn);
+  for(int d=0;d<2;++d) for(int b=0;b<4;++b) { y[BState(d,b)]=E_L;
+    y[BState(d,b,1)]=h; y[BState(d,b,2)]=n; }
+  for(int i=0;i<MAX_PORT;++i) for(int b=0;b<4;++b) { y[BSyn(i,b)]=0.f; y[BSyn(i,b,1)]=0.f; }
+  for(int i=0;i<n_port;++i) { g(i)=0.f; g1(i)=0.f; E_rev(i)=0.f;
+    tau_decay(i)=20.f; tau_rise(i)=2.f; compartment(i)=1.f; }
+}
+__device__ void NodeCalibrate(int n_var,int,double,float*y,float*param,user_m7_rk5)
+{
+  int n_port=(n_var-N_SCAL_VAR)/N_PORT_VAR; refractory_step=0.f;
+  for(int d=0;d<2;++d) for(int b=0;b<4;++b) {
+    y[BState(d,b,1)]=fminf(1.f,fmaxf(0.f,y[BState(d,b,1)]));
+    y[BState(d,b,2)]=fminf(1.f,fmaxf(0.f,y[BState(d,b,2)])); }
+  for(int i=0;i<n_port;++i) { float d1=tau_decay(i)-tau_rise(i), d2=0.f;
+    if(d1!=0.f) { float tp=tau_decay(i)*tau_rise(i)*log(tau_decay(i)/tau_rise(i))/d1;
+      d2=exp(-tp/tau_decay(i))-exp(-tp/tau_rise(i)); }
+    g0(i)=d2==0.f?M_E/tau_decay(i):(1.f/tau_rise(i)-1.f/tau_decay(i))/d2; }
+}
+}
+__device__ void NodeInit(int nv,int np,double x,float*y,float*p,user_m7_rk5 d)
+{ user_m7_ns::NodeInit(nv,np,x,y,p,d); }
+__device__ void NodeCalibrate(int nv,int np,double x,float*y,float*p,user_m7_rk5 d)
+{ user_m7_ns::NodeCalibrate(nv,np,x,y,p,d); }
+using namespace user_m7_ns;
+int user_m7::Init(int i0,int nn,int np,int ig)
+{
+  BaseNeuron::Init(i0,nn,np,ig); node_type_=i_user_m7_model;
+  n_scal_var_=N_SCAL_VAR; n_port_var_=N_PORT_VAR; n_scal_param_=N_SCAL_PARAM;
+  n_port_param_=N_PORT_PARAM; n_group_param_=N_GROUP_PARAM;
+  n_var_=n_scal_var_+n_port_var_*np; n_param_=n_scal_param_+n_port_param_*np;
+  group_param_=new float[N_GROUP_PARAM]; scal_var_name_storage_=new std::string[N_SCAL_VAR];
+  scal_param_name_storage_=new std::string[N_SCAL_PARAM];
+  const char* legacy_v[5]={"V_m","V_d","V_dist","I_adap","I_dep"};
+  for(int i=0;i<5;++i) scal_var_name_storage_[i]=legacy_v[i];
+  for(int d=0;d<2;++d) for(int b=0;b<4;++b) { std::string s=(d==0?"prox_":"dist_")+std::to_string(b);
+    scal_var_name_storage_[BState(d,b)]="V_b_"+s; scal_var_name_storage_[BState(d,b,1)]="h_Na_"+s;
+    scal_var_name_storage_[BState(d,b,2)]="n_Kd_"+s; }
+  for(int p=0;p<20;++p) for(int b=0;b<4;++b) { std::string s=std::to_string(p)+"_"+std::to_string(b);
+    scal_var_name_storage_[BSyn(p,b)]="branch_g_"+s; scal_var_name_storage_[BSyn(p,b,1)]="branch_g1_"+s; }
+  const char* legacy_p[21]={"V_th","E_L","C_m","tau_m","k_adap","k1","k2","A1","A2","I_e",
+    "V_peak","V_reset","t_ref","dend_C_frac","dend_leak_scale","g_c","dist_C_frac",
+    "dist_leak_scale","g_c_dist","refractory_step","den_delay"};
+  for(int i=0;i<21;++i) scal_param_name_storage_[i]=legacy_p[i];
+  const char* stems[10]={"C_b_prox","C_b_dist","g_leak_b_prox","g_leak_b_dist","g_ax_b_prox",
+    "g_ax_b_dist","gbar_Na_prox","gbar_Na_dist","gbar_Kd_prox","gbar_Kd_dist"};
+  for(int s=0;s<10;++s) for(int b=0;b<4;++b) scal_param_name_storage_[21+s*4+b]=
+    std::string(stems[s])+"_"+std::to_string(b);
+  const char* channel[10]={"E_Na","Vm_half","km","Vh_half","kh","tau_h","E_K","Vn_half","kn","tau_n"};
+  for(int i=0;i<10;++i) scal_param_name_storage_[61+i]=channel[i];
+  scal_var_name_=scal_var_name_storage_; port_var_name_=user_m7_port_var_name;
+  scal_param_name_=scal_param_name_storage_; port_param_name_=user_m7_port_param_name;
+  group_param_name_=user_m7_group_param_name; rk5_data_struct_.i_node_0_=i_node_0_;
+  SetGroupParam("h_min_rel",1.e-3); SetGroupParam("h0_rel",1.e-2); h_=h0_rel_*.1f;
+  rk5_.Init(nn,n_var_,n_param_,0.,h_,rk5_data_struct_); var_arr_=rk5_.GetYArr(); param_arr_=rk5_.GetParamArr();
+  port_weight_arr_=GetParamArr()+n_scal_param_+GetPortParamIdx("g0"); port_weight_arr_step_=n_param_;
+  port_weight_port_step_=n_port_param_; port_input_arr_=GetVarArr()+n_scal_var_+GetPortVarIdx("g1");
+  port_input_arr_step_=n_var_; port_input_port_step_=n_port_var_;
+  branch_port_input_arr_=GetVarArr()+BSyn(0,0,1); branch_port_input_arr_step_=n_var_;
+  branch_port_input_port_step_=MAX_BRANCH*2; branch_port_input_branch_step_=2;
+  den_delay_arr_=GetParamArr()+GetScalParamIdx("den_delay"); return 0;
+}
+int user_m7::Calibrate(double t,float dt)
+{ h_min_=h_min_rel_*dt; h_=h0_rel_*dt; rk5_.Calibrate(t,h_,rk5_data_struct_); return 0; }
+template<> int user_m7::UpdateNR<0>(long long,double){return 0;}
+int user_m7::Update(long long it,double t){UpdateNR<USER_M7_MAX_PORT_NUM>(it,t);return 0;}
diff --git a/src/user_m7.h b/src/user_m7.h
