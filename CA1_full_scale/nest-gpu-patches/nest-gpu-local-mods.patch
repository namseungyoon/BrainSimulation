+__device__ __forceinline__ int userM7Lane( int port, uint64_t u )
+{
+  int n_site = ( port == 0 ? 24 : ( port == 10 ? 18 : 18 ) );
+  int site = ( int ) __umul64hi( u, ( uint64_t ) n_site );
+  if ( port == 0 ) return site < 12 ? 0 : 1;             // Pyr, apical >100
+  if ( port == 10 ) return site < 9 ? 0 : 1;             // O-LM, apical >200
+  if ( site < 4 ) return 0;                              // 50--200 table
+  if ( site < 8 ) return 1;
+  if ( site < 13 ) return 2;
+  return 3;
+}
+
+__device__ __forceinline__ int userM7Contacts( int port )
+{
+  if ( port == 0 ) return 3;
+  if ( port == 3 ) return 2;
+  if ( port == 10 || port == 12 || port == 17 ) return 10;
+  return 1;
+}
