+  gpuErrchk( cudaMemcpy( d_target, target, n_node * sizeof( inode_t ), cudaMemcpyHostToDevice ) );
+  int ret = conn_->connectExplicitArrays( d_source, d_target, n_node, weight, delay, port, syn_group );
+  CUDAFREECTRL( "d_source", d_source );
+  CUDAFREECTRL( "d_target", d_target );
