+__device__ __forceinline__ uint userM6SourceHash( uint source )
+{
+  source ^= source >> 16;
+  source *= 0x7feb352dU;
+  source ^= source >> 15;
+  source *= 0x846ca68bU;
+  return source ^ ( source >> 16 );
+}
+
+__device__ __forceinline__ uint64_t splitMix64( uint64_t value )
+{
+  uint64_t z = value + 0x9E3779B97F4A7C15ULL;
+  z = ( z ^ ( z >> 30 ) ) * 0xBF58476D1CE4E5B9ULL;
+  z = ( z ^ ( z >> 27 ) ) * 0x94D049BB133111EBULL;
+  return z ^ ( z >> 31 );
+}
