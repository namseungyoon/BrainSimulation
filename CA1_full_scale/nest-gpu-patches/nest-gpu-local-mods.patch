+    The arrays remain strongly referenced for the duration of each synchronous
+    Connect call.  Large one-to-one groups are split at NEST-GPU's connection
+    block size without changing their order or synapse specification.
+    """
+    source = _uint32_group_array(source, "source")
+    target = _uint32_group_array(target, "target")
+    if conn_dict.get("rule") != "one_to_one":
+        raise ValueError("uint32 bulk connect only supports one_to_one")
+    if len(source) != len(target):
+        raise ValueError("source and target lengths differ")
+    ret = 0
+    for first in range(0, len(source), _CONNECT_GROUP_GROUP_MAX_EDGES):
+        last = min(first + _CONNECT_GROUP_GROUP_MAX_EDGES, len(source))
+        # Slices of C-contiguous 1-D arrays remain C-contiguous views.  Keep
+        # both views alive until Connect returns synchronously.
+        source_chunk = source[first:last]
+        target_chunk = target[first:last]
+        ret = Connect(source_chunk, target_chunk, conn_dict, syn_dict)
+    return ret
