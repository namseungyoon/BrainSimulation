+// Fill every field of a local explicit one-to-one connection in one pass.
+// Calling the layout-specialized setters in the same order as the legacy path
+// preserves its exact packed representation for both conn12b and conn16b.
+template < class ConnKeyT, class ConnStructT >
+__global__ void
+setExplicitArraysFused( ConnKeyT* conn_key_subarray,
+  ConnStructT* conn_struct_subarray,
+  int64_t n_block_conn,
+  int64_t n_prev_conn,
+  const inode_t* source,
+  const inode_t* target,
+  float weight,
+  int delay,
+  int port,
+  int syn_group )
+{
+  int64_t i_block_conn = threadIdx.x + blockIdx.x * blockDim.x;
+  if ( i_block_conn >= n_block_conn )
+  {
+    return;
+  }
+  int64_t i_conn = n_prev_conn + i_block_conn;
+  ConnKeyT& conn_key = conn_key_subarray[ i_block_conn ];
+  ConnStructT& conn_struct = conn_struct_subarray[ i_block_conn ];
+  setConnSource< ConnKeyT >( conn_key, source[ i_conn ] );
+  setConnTarget< ConnStructT >( conn_struct, target[ i_conn ] );
+  conn_struct.weight = weight;
+  setConnDelay< ConnKeyT >( conn_key, delay );
+  setConnPort< ConnKeyT, ConnStructT >( conn_key, conn_struct, port );
+  setConnSyn< ConnKeyT, ConnStructT >( conn_key, conn_struct, syn_group );
+}
