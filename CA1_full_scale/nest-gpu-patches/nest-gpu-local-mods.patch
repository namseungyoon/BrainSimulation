+
+#define USER_M3_MAX_PORT_NUM 20
+
+struct user_m3_rk5
+{
+  int i_node_0_;
+};
+
+class user_m3 : public BaseNeuron
+{
+public:
+  RungeKutta5< user_m3_rk5 > rk5_;
+  float h_min_;
+  float h_;
+  user_m3_rk5 rk5_data_struct_;
+
+  int Init( int, int, int, int );
+  int Calibrate( double, float );
+  int Update( long long, double );
+
+  int GetX( int i_neuron, int n_node, double* x ) { return rk5_.GetX( i_neuron, n_node, x ); }
+  int GetY( int i_var, int i_neuron, int n_node, float* y )
+  {
+    return rk5_.GetY( i_var, i_neuron, n_node, y );
+  }
+
+  template < int N_PORT > int UpdateNR( long long, double );
+};
+
+#endif
diff --git a/src/user_m3_kernel.h b/src/user_m3_kernel.h
new file mode 100644
index 0000000..6b1ce33
--- /dev/null
+++ b/src/user_m3_kernel.h
@@ -0,0 +1,208 @@
+#ifndef USERM3KERNEL_H
+#define USERM3KERNEL_H
+
+#include "node_group.h"
+#include "spike_buffer.h"
+#include "user_m3.h"
+#include <cmath>
+#include <string>
+
+extern __constant__ float NESTGPUTimeResolution;
+
+namespace user_m3_ns
+{
+enum ScalVarIndexes
+{
+  i_V_m = 0, i_V_d, i_V_dist, i_I_adap, i_I_dep, i_h, N_SCAL_VAR
+};
+enum PortVarIndexes { i_g = 0, i_g1, N_PORT_VAR };
+enum ScalParamIndexes
+{
+  i_V_th = 0, i_E_L, i_C_m, i_tau_m, i_k_adap, i_k1, i_k2, i_A1, i_A2,
+  i_I_e, i_V_peak, i_V_reset, i_t_ref, i_dend_C_frac, i_dend_leak_scale,
+  i_g_c, i_dist_C_frac, i_dist_leak_scale, i_g_c_dist, i_refractory_step,
+  i_den_delay, i_V_h_half, i_k_h, i_tau_h, i_delta_h, i_h_crit, N_SCAL_PARAM
+};
+enum PortParamIndexes { i_E_rev = 0, i_tau_rise, i_tau_decay, i_g0, i_compartment, N_PORT_PARAM };
+enum GroupParamIndexes { i_h_min_rel = 0, i_h0_rel, N_GROUP_PARAM };
+
+const std::string user_m3_scal_var_name[ N_SCAL_VAR ] =
+  { "V_m", "V_d", "V_dist", "I_adap", "I_dep", "h" };
+const std::string user_m3_port_var_name[ N_PORT_VAR ] = { "g", "g1" };
+const std::string user_m3_scal_param_name[ N_SCAL_PARAM ] = { "V_th", "E_L", "C_m", "tau_m",
+  "k_adap", "k1", "k2", "A1", "A2", "I_e", "V_peak", "V_reset", "t_ref",
+  "dend_C_frac", "dend_leak_scale", "g_c", "dist_C_frac", "dist_leak_scale",
+  "g_c_dist", "refractory_step", "den_delay", "V_h_half", "k_h", "tau_h",
+  "delta_h", "h_crit" };
+const std::string user_m3_port_param_name[ N_PORT_PARAM ] =
+  { "E_rev", "tau_rise", "tau_decay", "g0", "compartment" };
+const std::string user_m3_group_param_name[ N_GROUP_PARAM ] = { "h_min_rel", "h0_rel" };
+
+#define V_m y[ i_V_m ]
+#define V_d y[ i_V_d ]
+#define V_dist y[ i_V_dist ]
+#define I_adap y[ i_I_adap ]
+#define I_dep y[ i_I_dep ]
+#define sodium_h y[ i_h ]
+#define g( i ) y[ N_SCAL_VAR + N_PORT_VAR * i + i_g ]
+#define g1( i ) y[ N_SCAL_VAR + N_PORT_VAR * i + i_g1 ]
+#define dVdt dydx[ i_V_m ]
+#define dVddt dydx[ i_V_d ]
+#define dVdistdt dydx[ i_V_dist ]
+#define dI_adapdt dydx[ i_I_adap ]
+#define dI_depdt dydx[ i_I_dep ]
+#define dhdt dydx[ i_h ]
+#define dgdt( i ) dydx[ N_SCAL_VAR + N_PORT_VAR * i + i_g ]
+#define dg1dt( i ) dydx[ N_SCAL_VAR + N_PORT_VAR * i + i_g1 ]
+
+#define V_th param[ i_V_th ]
+#define E_L param[ i_E_L ]
+#define C_m param[ i_C_m ]
+#define tau_m param[ i_tau_m ]
+#define k_adap param[ i_k_adap ]
+#define k1 param[ i_k1 ]
+#define k2 param[ i_k2 ]
+#define A1 param[ i_A1 ]
+#define A2 param[ i_A2 ]
+#define I_e param[ i_I_e ]
+#define V_peak param[ i_V_peak ]
+#define V_reset param[ i_V_reset ]
+#define t_ref param[ i_t_ref ]
+#define dend_C_frac param[ i_dend_C_frac ]
+#define dend_leak_scale param[ i_dend_leak_scale ]
+#define g_c param[ i_g_c ]
+#define dist_C_frac param[ i_dist_C_frac ]
+#define dist_leak_scale param[ i_dist_leak_scale ]
+#define g_c_dist param[ i_g_c_dist ]
+#define refractory_step param[ i_refractory_step ]
+#define den_delay param[ i_den_delay ]
+#define V_h_half param[ i_V_h_half ]
+#define k_h param[ i_k_h ]
+#define tau_h param[ i_tau_h ]
+#define delta_h param[ i_delta_h ]
+#define h_crit param[ i_h_crit ]
+#define E_rev( i ) param[ N_SCAL_PARAM + N_PORT_PARAM * i + i_E_rev ]
+#define tau_rise( i ) param[ N_SCAL_PARAM + N_PORT_PARAM * i + i_tau_rise ]
+#define tau_decay( i ) param[ N_SCAL_PARAM + N_PORT_PARAM * i + i_tau_decay ]
+#define g0( i ) param[ N_SCAL_PARAM + N_PORT_PARAM * i + i_g0 ]
+#define compartment( i ) param[ N_SCAL_PARAM + N_PORT_PARAM * i + i_compartment ]
+#define h_min_rel_ group_param_[ i_h_min_rel ]
+#define h0_rel_ group_param_[ i_h0_rel ]
+
+__device__ inline float
+SodiumHInf( float voltage, float half, float slope )
+{
+  float exponent = ( voltage - half ) / slope;
+  exponent = fminf( 80.0f, fmaxf( -80.0f, exponent ) );
+  return 1.0f / ( 1.0f + expf( exponent ) );
+}
+
+template < int NVAR, int NPARAM >
+__device__ void
+Derivatives( double, float* y, float* dydx, float* param, user_m3_rk5 )
+{
+  enum { n_port = ( NVAR - N_SCAL_VAR ) / N_PORT_VAR };
+  float I_soma = 0.0f, I_prox = 0.0f, I_dist = 0.0f;
+  // The legacy peak cap is retained on the ordinary spiking branch. Once Na
+  // availability suppresses a crossing, use the real unreset voltage so leak,
+  // coupling and adaptation can establish a finite depolarized plateau.
+  const float V = refractory_step > 0.0f ? V_reset
+    : ( sodium_h <= h_crit ? V_m : fminf( V_m, V_peak ) );
+  for ( int i = 0; i < n_port; ++i )
+  {
+    if ( compartment( i ) < 0.5f ) I_soma += g( i ) * ( E_rev( i ) - V );
+    else if ( compartment( i ) < 1.5f ) I_prox += g( i ) * ( E_rev( i ) - V_d );
+    else I_dist += g( i ) * ( E_rev( i ) - V_dist );
+  }
+  float dend_frac = fminf( 0.95f, fmaxf( 1.0e-6f, dend_C_frac ) );
+  float dist_frac = fminf( 0.95f, fmaxf( 1.0e-6f, dist_C_frac ) );
+  float C_dend_total = C_m * dend_frac;
+  float C_dist = fmaxf( 1.0e-6f, C_dend_total * dist_frac );
+  float C_prox = fmaxf( 1.0e-6f, C_dend_total - C_dist );
+  float C_soma = fmaxf( 1.0e-6f, C_m - C_dend_total );
+  float soma_leak = -( C_soma / tau_m ) * ( V - E_L );
+  float prox_leak = -( C_prox / tau_m ) * dend_leak_scale * ( V_d - E_L );
+  float dist_leak = -( C_dist / tau_m ) * dist_leak_scale * ( V_dist - E_L );
+  float soma_coupling = g_c * ( V_d - V );
+  float prox_soma_coupling = g_c * ( V - V_d );
+  float prox_dist_coupling = g_c_dist * ( V_dist - V_d );
+  float dist_coupling = g_c_dist * ( V_d - V_dist );
+
+  dVdt = refractory_step > 0.0f ? 0.0f
+    : ( soma_leak + soma_coupling - I_adap + I_dep + I_soma + I_e ) / C_soma;
+  dVddt = ( prox_leak + prox_soma_coupling + prox_dist_coupling + I_prox ) / C_prox;
+  dVdistdt = ( dist_leak + dist_coupling + I_dist ) / C_dist;
+  dI_adapdt = k_adap * ( V - E_L ) - k2 * I_adap;
+  dI_depdt = -k1 * I_dep;
+  dhdt = ( SodiumHInf( V, V_h_half, k_h ) - sodium_h ) / tau_h;
+  for ( int i = 0; i < n_port; ++i )
+  {
+    dg1dt( i ) = -g1( i ) / tau_rise( i );
+    dgdt( i ) = g1( i ) - g( i ) / tau_decay( i );
+  }
+}
+
+template < int NVAR, int NPARAM >
+__device__ void
+ExternalUpdate( double, float* y, float* param, bool end_time_step, user_m3_rk5 data_struct )
+{
+  sodium_h = fminf( 1.0f, fmaxf( 0.0f, sodium_h ) );
+  if ( V_m < -1.0e3f || V_d < -1.0e3f || V_dist < -1.0e3f )
+  {
+    printf( "membrane voltage out of lower bound\n" );
+    V_m = V_reset; V_d = E_L; V_dist = E_L; I_adap = 0.0f; I_dep = 0.0f;
+    sodium_h = SodiumHInf( E_L, V_h_half, k_h );
+    return;
+  }
+  if ( I_adap < -1.0e6f || I_adap > 1.0e6f || I_dep < -1.0e6f || I_dep > 1.0e6f )
+  {
+    printf( "adaptation current out of bound\n" );
+    V_m = V_reset; I_adap = 0.0f; I_dep = 0.0f;
+    return;
+  }
+  if ( refractory_step > 0.0f )
+  {
+    V_m = V_reset;
+    if ( end_time_step ) refractory_step -= 1.0f;
+    return;
+  }
+  if ( V_m >= V_th && sodium_h > h_crit )
+  {
+    int neuron_idx = threadIdx.x + blockIdx.x * blockDim.x;
+    PushSpike( data_struct.i_node_0_ + neuron_idx, 1.0 );
+    sodium_h = fmaxf( 0.0f, sodium_h - delta_h );
+    V_m = V_reset;
+    I_adap += A2;
+    I_dep = A1;
+    refractory_step = ( int ) round( t_ref / NESTGPUTimeResolution );
+    if ( refractory_step < 0.0f ) refractory_step = 0.0f;
+  }
+  // A threshold crossing with h <= h_crit is deliberately left unreset.
+}
+} // namespace user_m3_ns
+
+template <> int user_m3::UpdateNR< 0 >( long long, double );
+template < int N_PORT >
+int user_m3::UpdateNR( long long it, double t1 )
+{
+  if ( N_PORT == n_port_ )
+  {
+    const int NVAR = user_m3_ns::N_SCAL_VAR + user_m3_ns::N_PORT_VAR * N_PORT;
+    const int NPARAM = user_m3_ns::N_SCAL_PARAM + user_m3_ns::N_PORT_PARAM * N_PORT;
+    rk5_.Update< NVAR, NPARAM >( t1, h_min_, rk5_data_struct_ );
+  }
+  else UpdateNR< N_PORT - 1 >( it, t1 );
+  return 0;
+}
+template < int NVAR, int NPARAM >
+__device__ void Derivatives( double x, float* y, float* dydx, float* param, user_m3_rk5 data_struct )
+{
+  user_m3_ns::Derivatives< NVAR, NPARAM >( x, y, dydx, param, data_struct );
+}
+template < int NVAR, int NPARAM >
+__device__ void ExternalUpdate( double x, float* y, float* param, bool end, user_m3_rk5 data_struct )
+{
+  user_m3_ns::ExternalUpdate< NVAR, NPARAM >( x, y, param, end, data_struct );
+}
+
+#endif
