# Runtime crash/backtrace logs
python.80s-*.btr

# Ephemeral agent scratch + stray design logs (figures under docs/generated stay tracked)
scratchpad/
docs/generated/*.log
docs/generated/**/debug/

# Large all-figures presentation (regenerable via scratchpad/build_pptx.py)
docs/generated/CA1_all_figures_ko.pptx

docs/generated/CA1_technical_story_ko.pptx

# Large generated presentation decks + interactive topology viz (regenerable; kept local, per project policy: repo = code + result PNGs only)
*.pptx
docs/generated/**/*.html
